# Stage 1: Build Vue frontend
FROM node:22-bookworm-slim AS frontend-build
WORKDIR /frontend
COPY frontend/package.json frontend/package-lock.json* ./
RUN npm install --frozen-lockfile 2>/dev/null || npm install
COPY frontend/ ./
RUN npx vite build --outDir dist

# Stage 2: Python backend
FROM python:3.12-slim
WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends curl tzdata && \
    rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir uv

COPY backend/pyproject.toml .

RUN uv pip install --system flask flask-cors openai pydantic python-dotenv \
    numpy aiohttp rich click databento google-cloud-storage \
    gunicorn tzdata zep-cloud 2>/dev/null || \
    pip install --no-cache-dir flask flask-cors openai pydantic python-dotenv \
    numpy aiohttp rich click databento google-cloud-storage \
    gunicorn tzdata zep-cloud

COPY backend/app/ /app/app/
COPY backend/seed_data/ /app/seed_data/
COPY backend/openbb/ /app/openbb/
COPY scripts/ /app/scripts/

# Copy built frontend from Stage 1
COPY --from=frontend-build /frontend/dist /app/static/

RUN mkdir -p /app/output /app/logs

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
ENV PORT=8080
EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s \
    CMD curl -f http://localhost:${PORT}/api/health || exit 1

CMD ["sh", "-c", "exec gunicorn --bind :${PORT:-8080} --workers 1 --threads 8 --timeout 3600 --keep-alive 75 'app.main:create_app()'"]
