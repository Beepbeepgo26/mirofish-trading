# ──────────────────────────────────────────────────────────────
# MiroFish Trading Simulation — Environment Configuration
# ──────────────────────────────────────────────────────────────

# Primary LLM (institutional agents, report generation)
# Must be OpenAI-compatible. Recommended: GPT-4o, Claude via proxy, Qwen-Plus
LLM_API_KEY=sk-your-primary-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o

# Boost LLM (retail/noise agents — can use cheaper model)
LLM_BOOST_API_KEY=sk-your-boost-key
LLM_BOOST_BASE_URL=https://api.openai.com/v1
LLM_BOOST_MODEL_NAME=gpt-4o-mini

# Zep Cloud — Knowledge graph memory
# Free tier supports simple use: https://app.getzep.com/
ZEP_API_KEY=z_your-zep-key

# Databento — ES futures market data (historical + live)
# Get key at: https://databento.com/portal/keys
# Requires CME Globex MDP 3.0 subscription for live data
DATABENTO_API_KEY=db-your-databento-key

# Simulation defaults
SIM_MAX_ROUNDS=30
SIM_AGENTS_INSTITUTIONAL=7
SIM_AGENTS_RETAIL=40
SIM_AGENTS_MARKET_MAKER=3
SIM_AGENTS_NOISE=20
SIM_CONCURRENCY=10

# Google Cloud Storage — results bucket (auto-created by deploy script)
# Leave empty for local-only mode (results lost on Cloud Run scale-to-zero)
GCS_BUCKET=

# Backend
FLASK_PORT=5001
FLASK_DEBUG=false

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
